# =====================================================================
# GLM Power Platform — Environment Variables
# ---------------------------------------------------------------------
# Copy this file to .env and fill in the values you have.
# Everything works without keys except live GLM responses + voice
# transcription — the UI shows clear status for each.
# =====================================================================

# ----- Core -----
DATABASE_URL="file:./db/custom.db"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Set to "1" ONLY in dev/preview to allow chat without auth.
# In production, leave unset or empty — unauthenticated requests get 401.
# Railway production auto-disables this via railway.json.
ENABLE_DEMO_MODE=""

# Set to "1" to permanently disable self-service sign-ups. Existing
# users can still sign in. Useful for private/invite-only instances.
DISABLE_SIGNUP=""

# ----- Redis (shared state across replicas) -----
# Optional but strongly recommended for production / multi-replica.
# If unset: distillation state + rate limits fall back to in-memory
# (single-replica only). Works fine for dev + small single-replica deploys.
# Railway: use the Upstash Redis or Redis add-on.
REDIS_URL=""

# ----- Transactional email (password reset) -----
# Optional. If unset: emails are logged to the console (dev mode).
# Format: smtp://user:pass@smtp.host:587 or smtps:// for TLS.
# Railway: use the SMTP add-on or any external provider (Resend, SES, etc.)
SMTP_URL=""
EMAIL_FROM="GLM Power Platform <noreply@yourdomain.com>"

# ----- GLM / Z.ai API (the only required key for live chat + voice) -----
# Get this at https://z.ai or https://open.bigmodel.cn
# Used for BOTH: GLM 5.2 chat completions AND Z.ai ASR (voice input)
# Higher tier = higher rate limits = no kick-down to lesser model
ZAI_API_KEY=""

# ----- Voice input (optional fallback) + RAG embeddings (primary) -----
# One key, two jobs: Whisper STT fallback AND text-embedding-3-small
# for RAG document indexing (the primary embedding provider).
OPENAI_API_KEY=""

# ----- DeepSeek (optional second chat provider, merged from ragdb) -----
# Enables the DeepSeek Reasoner (visible thinking trace) + DeepSeek Chat
# models in the model picker. https://platform.deepseek.com
DEEPSEEK_API_KEY=""

# ----- RAG (document intelligence) -----
# Embeddings provider: auto | openai | zai | local
#   auto (default): openai if OPENAI_API_KEY set, else zai, else local.
#   local = deterministic 256-dim hash embeddings — zero keys, dev-grade.
RAG_EMBEDDINGS_PROVIDER="auto"
# Retrieval driver: local | supabase
#   local (default): exact cosine over Prisma-stored vectors. No infra.
#   supabase: pgvector HNSW accelerator — run supabase/rag/101_rag_pgvector.sql,
#   set SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY, use openai/zai embeddings.
RAG_DRIVER="local"
# Server-only. Required only for RAG_DRIVER=supabase.
SUPABASE_SERVICE_ROLE_KEY=""

# ----- Connector keys (drop in as you get them) -----
# Legal research
COURTLISTENER_API_TOKEN=""        # https://www.courtlistener.com/help/api/rest/
MIDPAGE_API_KEY=""                # https://midpage.ai
COURTROOM5_API_KEY=""             # https://courtroom5.com

# Productivity
NOTION_API_KEY=""                 # https://www.notion.so/profile/integrations

# Dev
GITHUB_TOKEN=""                   # https://github.com/settings/tokens (repo scope)
LOCAL_FS_ROOT=""                  # local only — skip on Railway

# ----- Backend credentials (drop in to enable data backend integration) -----
# Stored encrypted in DB; these env vars are fallbacks only.
# Supabase: https://supabase.com/dashboard/project/_/settings/api
# Neon: https://neon.tech/docs/connect/connection-pooling
# MongoDB: https://www.mongodb.com/docs/atlas/connect-to-standard-deployment/
# Firebase: https://firebase.google.com/docs/admin/setup
# Turso: https://docs.turso.tech/connect
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
NEON_CONNECTION_STRING=""
MONGODB_CONNECTION_STRING=""
FIREBASE_SERVICE_ACCOUNT=""
TURSO_URL=""
TURSO_AUTH_TOKEN=""

# ----- Encryption key for stored integration/backend credentials -----
# 32+ chars, random. Generate with: openssl rand -hex 32
INTEGRATION_ENCRYPTION_KEY=""

# ----- Stripe (REAL implementation — feature-flagged) -----
# Set these to enable billing. Without them, billing routes return
# "not configured" gracefully — app still works.
# Docs: https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_POWER=""             # free, set to anything if you want a checkout
STRIPE_PRICE_TEAM=""              # price ID for Team plan ($29/mo)
STRIPE_PRICE_PRO=""               # price ID for Pro plan ($49/mo)

# ----- Production flags -----
DISABLE_SEED="0"
